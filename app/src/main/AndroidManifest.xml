<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.XLyraWidget"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.XLyraWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/xlyra_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.XLyraWidget4x2Receiver"
            android:exported="true"
            android:label="@string/widget_name_4x2">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/xlyra_widget_4x2_info" />
        </receiver>

        <receiver
            android:name=".widget.XLyraWidget4x1Receiver"
            android:exported="true"
            android:label="@string/widget_name_4x1">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/xlyra_widget_4x1_info" />
        </receiver>

        <receiver
            android:name=".widget.XLyraWidgetCost2x1Receiver"
            android:exported="true"
            android:label="@string/widget_name_cost_2x1">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/xlyra_widget_cost_2x1_info" />
        </receiver>

        <receiver
            android:name=".widget.XLyraWidgetQuota2x1Receiver"
            android:exported="true"
            android:label="@string/widget_name_quota_2x1">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/xlyra_widget_quota_2x1_info" />
        </receiver>
    </application>
</manifest>
