<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="xLyra"
            android:textColor="#0F172A"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="刷新 --"
            android:textColor="#64748B"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_refresh"
            android:layout_width="42dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_refresh_bg"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="↻"
            android:textColor="#0F766E"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/WidgetMetricLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今日成本" />

            <TextView
                android:id="@+id/widget_cost_today"
                style="@style/WidgetMetricValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/WidgetMetricLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="累计成本" />

            <TextView
                android:id="@+id/widget_total_cost"
                style="@style/WidgetMetricValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/WidgetMetricLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今日请求" />

            <TextView
                android:id="@+id/widget_requests_today"
                style="@style/WidgetMetricValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/WidgetMetricLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今日 Tokens" />

            <TextView
                android:id="@+id/widget_tokens_today"
                style="@style/WidgetMetricValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/WidgetMetricLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RPM / TPM" />

            <TextView
                android:id="@+id/widget_rate"
                style="@style/WidgetMetricValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-- / --"
                android:textSize="17sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="34dp"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="5h"
                android:textColor="#334155"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_5h_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_progress_green" />

            <TextView
                android:id="@+id/widget_5h_value"
                android:layout_width="42dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:includeFontPadding="false"
                android:text="--"
                android:textColor="#0F172A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_5h_reset"
                android:layout_width="58dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:includeFontPadding="false"
                android:text="--"
                android:textColor="#64748B"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="34dp"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="7d"
                android:textColor="#334155"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_7d_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_progress_green" />

            <TextView
                android:id="@+id/widget_7d_value"
                android:layout_width="42dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:includeFontPadding="false"
                android:text="--"
                android:textColor="#0F172A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_7d_reset"
                android:layout_width="58dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:includeFontPadding="false"
                android:text="--"
                android:textColor="#64748B"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_model_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Top1 --"
            android:textColor="#334155"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_model_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Top2 --"
            android:textColor="#334155"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
